<!DOCTYPE html>

<html lang="en">

<head>
  <meta charset="utf-8" />
  <title>BrightScript Code Editor</title>
  <meta name="description" content="Simple Code Editor for playing with BrightScript language." />
  <meta name="author" content="Marcelo Lv Cabral" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" href="./images/favicon.ico" type="image/x-icon" />
  <link rel="stylesheet" href="css/editor.css" />
  <link rel="stylesheet" href="css/fontello.css" />
  <link rel="stylesheet" href="themes/vscode-dark.css" />
  <link rel="stylesheet" href="themes/material-palenight.css" />
  <link rel="stylesheet" href="themes/coda.css" />
</head>

<body id="root" class="index-page">
  <header id='titlebar'>
    <div id='drag-region'>
      <div id='window-title'>
        <span>BrightScript Code Editor</span>
      </div>
      <div id='window-controls'>
        <div class='button' id='close-button'>
          <img class='icon' id='close-button-dark'
            srcset='icons/close-w-10.png 1x, icons/close-w-12.png 1.25x, icons/close-w-15.png 1.5x, icons/close-w-15.png 1.75x, icons/close-w-20.png 2x, icons/close-w-20.png 2.25x, icons/close-w-24.png 2.5x, icons/close-w-30.png 3x, icons/close-w-30.png 3.5x'
            draggable='false' /><img class='icon' id='close-button-light' style='display: none;'
            srcset='icons/close-k-10.png 1x, icons/close-k-12.png 1.25x, icons/close-k-15.png 1.5x, icons/close-k-15.png 1.75x, icons/close-k-20.png 2x, icons/close-k-20.png 2.25x, icons/close-k-24.png 2.5x, icons/close-k-30.png 3x, icons/close-k-30.png 3.5x'
            draggable='false' />
        </div>
      </div>
    </div>
  </header>
  <main class="main-container editor">
    <div class="code">
      <div class="code-header">
        <div>
          <h4>Code &nbsp;
            <select id="code-selector">
              <option value="0">&lt;&lt; New Code &gt;&gt;</option>
            </select>
            <button title="Code Tools" class="more-options" id="more-options">
              <i class="icon-wrench"></i>
              <div class="dropdown" id="more-options-dropdown">
                <ul>
                  <li><a href="#" id="rename-option"><i class="icon-edit"></i> Rename</a></li>
                  <li><a href="#" id="saveas-option"><i class="icon-save"></i> Save as</a></li>
                  <li><a href="#" id="delete-option"><i class="icon-trash"></i> Delete</a></li>
                  <li><a href="#" id="export-brs-option"><i class="icon-upload"></i> Export (brs)</a></li>
                  <li><a href="#" id="export-json-option"><i class="icon-upload"></i> Export (json)</a></li>
                  <li><a href="#" id="export-all-option"><i class="icon-upload"></i> Export All (json)</a></li>
                  <li><a href="#" id="import-option"><i class="icon-download"></i> Import (brs, json)</a></li>
                </ul>
              </div>
            </button>
          </h4>
        </div>
        <div>
          <button title="Run the Code" class="run">
            <i class="icon-play"></i>
            <span>RUN</span>
          </button>
          <button title="End the Execution" style="display:none" class="end">
            <i class="icon-stop"></i>
            <span>END</span>
          </button>
          <button title="Save the Code" class="save">
            <i class="icon-save"></i>
            <span>SAVE</span>
          </button>
          <button title="Share the Code" class="share">
            <i class="icon-share"></i>
            <span>SHARE</span>
          </button>
        </div>
      </div>
      <div class="editor-wrapper">
        <div id="brsCode"></div>
      </div>
    </div>
    <div class="layout-separator">
      <button class="collapse-button" id="collapse-button" title="Collapse Code Editor">
        <span>«</span>
      </button>
    </div>
    <div class="console">
      <div class="console-header">
        <div style="display: flex; align-items: center; gap: 10px;">
          <h4>Console</h4>
          <div id="console-search-container" class="console-search-container hidden">
            <input type="text" id="console-search-input" placeholder="Find in console..." />
            <span id="console-search-matches" class="console-search-matches">0/0</span>
            <button id="console-search-prev" title="Previous Match" class="icon-btn"><svg viewBox="0 0 24 24" width="14" height="14" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><polyline points="18 15 12 9 6 15"></polyline></svg></button>
            <button id="console-search-next" title="Next Match" class="icon-btn"><svg viewBox="0 0 24 24" width="14" height="14" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg></button>
            <button id="console-search-close" title="Close Search" class="icon-btn"><i class="icon-cancel"></i></button>
          </div>
        </div>
        <div>
          <button title="Search Console" id="console-search-btn" class="search-btn" style="display:inline-flex; align-items:center; justify-content:center;">
            <svg viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
          </button>
          <button title="Pause and Debug" style="display:none" class="break">
            <i class="icon-pause"></i>
            <span>DEBUG</span>
          </button>
          <button title="Resume the Execution" style="display:none" class="resume">
            <i class="icon-play"></i>
            <span>RESUME</span>
          </button>
          <button title="Clear All Logs" class="clear-all">
            <i class="icon-trash"></i>
            <span>CLEAR</span>
          </button>
        </div>
      </div>
      <div id="console-logs" class="active"></div>
    </div>
    <dialog id="code-dialog" class="modal_dialog" closed>
      <p class="modal_dialog_content">Enter the name of the code snippet:</p>
      <form method="dialog" id="code-form">
        <input type="text" name="codeName" class="modal_dialog_input" />
        <button value="ok">OK</button>
        <button value="cancel" class="modal_dialog_cancel">Cancel</button>
        <input type="hidden" id="actionType" value="save" />
      </form>
    </dialog>
    <dialog id="confirm-dialog" class="modal_dialog" closed>
      <p id="dialog-text" class="modal_dialog_content"></p>
      <br />
      <form method="dialog">
        <button id="confirm-button" value="ok">Yes</button>
        <button id="cancel-button" value="cancel" class="modal_dialog_cancel">No</button>
      </form>
    </dialog>
  </main>
</body>

</html>